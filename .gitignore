# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Project specific
live_transcript.txt
temp/
transcripts/
*.wav
*.mp3
*.mp4

# ...but DO commit session recordings captured alongside a run's logs, so they
# can be replayed (`--engine replay`) and frozen into regression tests.
!logs/runs/*.wav
!logs/runs/*.mp3

# Per-run pytest log bundles are transient (timestamped trace + summary for the
# machine they ran on); curated logs/runs/ bundles are committed, these are not.
logs/tests/

# Live-validation run artifacts (tools/live_session): large per-run wavs +
# machine-specific timelines. The analysis lives in docs/, not the raw bundles.
logs/live/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Local config (keep config.json as template)
config.local.json

# Local Claude Code session config (machine-local, never committed)
.claude/

# Environment variables
.env
.env.local

# Claude Code local config: machine-specific autonomy permissions + guard hook
# (hard-codes this machine's paths; not shared). Promote to .claude/settings.json
# with relative paths if you ever want it committed.
.claude/settings.local.json
.claude/hooks/

# Generated test reports (tools/run_tests.py)
test-reports/

# Swarm harness per-run churn; .agents/last_report.json is committed as the
# version verdict snapshot, but the append-only history is local noise.
.agents/history.jsonl

# Accidental cross-machine cruft / stray redirect output. `UsersPaul` was a
# stray GitHub-API 404 body written to a file; `social_media_activities_app/`
# is a SEPARATE project (its own .git) that was once nested here by mistake and
# now lives as a sibling repo -- guard so neither can ever be staged again.
UsersPaul
social_media_activities_app/

# Session-bootstrap briefings (tools/session_bootstrap.py) are machine-local and
# regenerated each session from the committed run-logs/handoff docs.
logs/session_*_bootstrap.md

# Downloaded model weights -- large binaries, NEVER commit. Fetch on each
# machine with `python -m tools.setup_models` (sherpa) or the phone GGUFs.
pretrained_models/sherpa/
# Downloaded sherpa-onnx model bundles (hundreds of MB; fetched on demand).
pretrained_models/sherpa-onnx-*/
models/
*.gguf
