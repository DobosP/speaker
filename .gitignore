*.mp4

# ...but DO commit session recordings captured alongside a run's logs, so they
# can be replayed (`--engine replay`) and frozen into regression tests.
!logs/runs/*.wav
!logs/runs/*.mp3

# Per-run pytest log bundles are transient (timestamped trace + summary for the
# machine they ran on); curated logs/runs/ bundles are committed, these are not.
logs/tests/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Local config (keep config.json as template)
config.local.json

# Environment variables
.env
.env.local

# Generated test reports (tools/run_tests.py)
test-reports/

# Swarm harness per-run churn; .agents/last_report.json is committed as the
# version verdict snapshot, but the append-only history is local noise.
.agents/history.jsonl

# Downloaded model weights -- large binaries, NEVER commit. Fetch on each
# machine with `python -m tools.setup_models` (sherpa) or the phone GGUFs.
pretrained_models/sherpa/
models/
*.gguf
