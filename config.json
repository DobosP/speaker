{
  "llm_model": "gemma3:latest",
  "mode": "assistant",
  "local_only": true,
  "sherpa": {
    "sample_rate": 16000,
    "asr_tokens": "",
    "asr_encoder": "",
    "asr_decoder": "",
    "asr_joiner": "",
    "vad_model": "",
    "tts_model": "",
    "tts_tokens": "",
    "tts_data_dir": "",
    "tts_speaker_id": 0,
    "tts_speed": 1.0,
    "speaker_embedding_model": "",
    "speaker_enroll_wav": "",
    "speaker_threshold": 0.5,
    "barge_in_min_speech_sec": 0.2,
    "num_threads": 2
  },
  "memory_smart_save": true,
  "memory_flush_interval_sec": 240,
  "memory_enable_embeddings": false,
  "memory_persist_assistant": false,
  "memory_llm_clean": true,
  "memory": {
    "save_interval_sec": 240,
    "min_confidence": 0.55,
    "llm_cleanup": true,
    "llm_gate": true,
    "cleanup_model": "gemma3:1b",
    "max_buffer_items": 32,
    "min_chars": 3,
    "dedupe_similarity": 0.92,
    "persist_user_only": true,
    "save_control_phrases": false
  },
  "agent_brain": {
    "model": "ollama/gemma3:latest",
    "api_base": "http://localhost:11434",
    "api_key_env": null,
    "offline": true,
    "local_only": true,
    "local_fallback_model": null,
    "vision_model": null,
    "os_mode": false,
    "web_tool": "oi",
    "screenshot_dir": null,
    "auto_run": false,
    "confirm_mode": "auto_safe",
    "allowlist": [
      "^ls\\b",
      "^pwd\\b",
      "^cat\\b",
      "^head\\b",
      "^tail\\b",
      "^echo\\b",
      "^date\\b",
      "^whoami\\b",
      "^df\\b",
      "^free\\b",
      "^uname\\b",
      "^uptime\\b",
      "^git status\\b",
      "^git log\\b",
      "^python3?\\s+-c\\b"
    ],
    "denylist": [
      "rm\\s+-rf",
      "\\bdd\\b",
      "mkfs",
      "\\bsudo\\b",
      ":\\(\\)\\s*\\{",
      "shutdown",
      "reboot",
      ">\\s*/dev/",
      "chmod\\s+-R",
      "chown\\s+-R",
      "curl[^|]*\\|\\s*(sh|bash)",
      "wget[^|]*\\|\\s*(sh|bash)"
    ],
    "max_output_chars": 2000
  }
}
