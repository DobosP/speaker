{
  "llm_model": "gemma3:12b",
  "device": "desktop",
  "llm": {
    "backend": "ollama",
    "main_model": "gemma3:12b",
    "fast_model": "gemma3:4b",
    "host": null,
    "keep_alive": "30m",
    "options": {
      "num_ctx": 4096
    },
    "router": {
      "backend": "heuristic",
      "threshold": 0.5
    },
    "cloud": {
      "enabled": false,
      "strategy": "hedge",
      "base_url": "https://api.groq.com/openai/v1",
      "model": "llama-3.3-70b-versatile",
      "api_key_env": "GROQ_API_KEY",
      "hedge_delay_ms": 150,
      "ttft_deadline_ms": 1200
    }
  },
  "device_profiles": {
    "desktop": {
      "llm": {
        "backend": "ollama",
        "main_model": "gemma3:12b",
        "fast_model": "gemma3:4b",
        "keep_alive": -1,
        "options": {
          "num_ctx": 4096,
          "num_predict": 384,
          "num_gpu": 999
        }
      },
      "sherpa": {
        "asr_num_threads": 4,
        "tts_num_threads": 2
      }
    },
    "desktop_gpu_4090": {
      "_comment": "RTX 4090 / 5090 / equivalent: gemma3:12b on GPU + gemma3:4b fast tier; both gates ON (fast tier has plenty of headroom). Specsim quick TTFA 0.96s. Cloud hedge off by default; flip llm.cloud.enabled in config.local.json to add cloud-backed research mode.",
      "llm": {
        "backend": "ollama",
        "main_model": "gemma3:12b",
        "fast_model": "gemma3:4b",
        "keep_alive": -1,
        "options": {
          "num_ctx": 8192,
          "num_predict": 512,
          "num_gpu": 999
        }
      },
      "sherpa": {
        "asr_num_threads": 4,
        "tts_num_threads": 2
      },
      "input_gate": {"enabled": true, "unsure_acts": true, "max_context": 4},
      "cleanup": {"enabled": true, "max_context": 3}
    },
    "macbook_m_series": {
      "_comment": "Apple Silicon (M2/M3/M4 + 16GB+ unified RAM): gemma3:4b main on Metal + gemma3:1b fast. Both gates ON. Specsim quick TTFA 1.46s. For research mode set llm.cloud.enabled=true with a DeepSeek/OpenAI/Together key to keep paragraph answers under 3s.",
      "llm": {
        "backend": "ollama",
        "main_model": "gemma3:4b",
        "fast_model": "gemma3:1b",
        "keep_alive": "30m",
        "options": {
          "num_ctx": 4096,
          "num_predict": 384
        }
      },
      "sherpa": {
        "asr_num_threads": 4,
        "tts_num_threads": 2
      },
      "input_gate": {"enabled": true, "unsure_acts": true, "max_context": 4},
      "cleanup": {"enabled": true, "max_context": 3}
    },
    "cpu_laptop": {
      "_comment": "Mid-range Windows/Linux laptop, no dedicated GPU (8 cores, 16GB). Local gemma3:1b only -- the 4b main is too slow on pure CPU (specsim quick TTFA would be ~3.5s+). Cloud hedge STRONGLY recommended for the main tier: enable llm.cloud, set the api_key_env var, and the hedge handles paragraph answers in ~1-2s. Both gates OFF (no fast-tier headroom on CPU).",
      "llm": {
        "backend": "ollama",
        "main_model": "gemma3:4b",
        "fast_model": "gemma3:1b",
        "keep_alive": "10m",
        "options": {
          "num_ctx": 2048,
          "num_predict": 256
        }
      },
      "sherpa": {
        "asr_num_threads": 4,
        "tts_num_threads": 2
      },
      "input_gate": {"enabled": false, "unsure_acts": true, "max_context": 4},
      "cleanup": {"enabled": false, "max_context": 3}
    },
    "phone": {
      "llm": {
        "backend": "llamacpp",
        "main_model_path": "models/gemma-3-4b-it-Q4_K_M.gguf",
        "fast_model_path": "models/gemma-3-1b-it-Q4_K_M.gguf",
        "n_ctx": 2048,
        "n_gpu_layers": 0,
        "options": {
          "temperature": 0.7
        }
      },
      "sherpa": {
        "num_threads": 2,
        "asr_num_threads": 2,
        "tts_num_threads": 1
      }
    },
    "phone_lite": {
      "_comment": "Low-end phone (6GB RAM, mid-range SoC): single-tier gemma3:1b GGUF Q4 only. The 4b model thrashes RAM at this tier. Cloud REQUIRED for research mode -- enable llm.cloud and set DEEPSEEK_API_KEY (or equivalent) for paragraph answers. Specsim quick TTFA on-device 5s; with cloud hedge 1-2s. Gates OFF.",
      "llm": {
        "backend": "llamacpp",
        "main_model_path": "models/gemma-3-1b-it-Q4_K_M.gguf",
        "fast_model_path": "models/gemma-3-1b-it-Q4_K_M.gguf",
        "n_ctx": 1536,
        "n_gpu_layers": 0,
        "options": {
          "temperature": 0.7
        }
      },
      "sherpa": {
        "num_threads": 2,
        "asr_num_threads": 1,
        "tts_num_threads": 1
      },
      "input_gate": {"enabled": false, "unsure_acts": true, "max_context": 4},
      "cleanup": {"enabled": false, "max_context": 3}
    }
  },
  "mode": "assistant",
  "local_only": true,
  "tts": {
    "streaming": true
  },
  "intents": {
    "enabled": true,
    "phrases": {}
  },
  "input_gate": {
    "_comment": "Optional ACT/INGEST gate (core/addressing.py). Disabled by default; enable to stop the assistant from answering ambient speech / read-aloud text. Needs llm.fast_model. unsure_acts=true preserves prior behavior; false is conservative (silently ingest).",
    "enabled": false,
    "unsure_acts": true,
    "max_context": 4
  },
  "cleanup": {
    "_comment": "Optional ASR transcript cleanup (core/cleanup.py). Disabled by default; enable to rewrite the raw final into the user's intended sentence -- drops fillers, resolves self-corrections, handles the word-repeat-at-end correction signal. Needs llm.fast_model. Adds one fast-tier LLM call per ACT'd final.",
    "enabled": false,
    "max_context": 3
  },
  "followups": {
    "enabled": false,
    "delay_sec": 3.0,
    "max_followups": 3,
    "markers": [
      "[silent]",
      "[no response]",
      "[still waiting]"
    ]
  },
  "agent": {
    "planner": {
      "enabled": false,
      "max_steps": 4,
      "tools": [
        "search.local",
        "research.scope",
        "research.local"
      ],
      "escalate": true
    }
  },
  "remote": {
    "room": "assistant",
    "agent_identity": "assistant-agent",
    "token_server_port": 8080
  },
  "sherpa": {
    "sample_rate": 16000,
    "asr_tokens": "",
    "asr_encoder": "",
    "asr_decoder": "",
    "asr_joiner": "",
    "vad_model": "",
    "tts_model": "",
    "tts_tokens": "",
    "tts_data_dir": "",
    "tts_speaker_id": 0,
    "tts_speed": 1.0,
    "speaker_embedding_model": "",
    "speaker_enroll_wav": "",
    "speaker_threshold": 0.5,
    "barge_in_min_speech_sec": 0.2,
    "kws_tokens": "",
    "kws_encoder": "",
    "kws_decoder": "",
    "kws_joiner": "",
    "kws_keywords_file": "",
    "kws_threshold": 0.25,
    "kws_score": 1.0,
    "provider": "cpu",
    "num_threads": 0,
    "asr_num_threads": 0,
    "tts_num_threads": 0
  },
  "commands": {
    "stop": "stop",
    "cancel": "stop",
    "quiet": "stop",
    "assistant mode": "mode:assistant",
    "command mode": "mode:command",
    "research mode": "mode:research",
    "dictation mode": "mode:dictation",
    "yes do it": "confirm",
    "never mind": "deny"
  },
  "memory_smart_save": true,
  "memory_flush_interval_sec": 240,
  "memory_enable_embeddings": false,
  "memory_persist_assistant": false,
  "memory_llm_clean": true,
  "memory": {
    "save_interval_sec": 240,
    "min_confidence": 0.55,
    "llm_cleanup": true,
    "llm_gate": true,
    "cleanup_model": "gemma3:4b",
    "max_buffer_items": 32,
    "min_chars": 3,
    "dedupe_similarity": 0.92,
    "persist_user_only": true,
    "save_control_phrases": false
  },
  "agent_brain": {
    "model": "ollama/gemma3:12b",
    "api_base": "http://localhost:11434",
    "api_key_env": null,
    "offline": true,
    "local_only": true,
    "local_fallback_model": null,
    "vision_model": "ollama/gemma3:12b",
    "os_mode": false,
    "web_tool": "oi",
    "screenshot_dir": null,
    "auto_run": false,
    "confirm_mode": "auto_safe",
    "allowlist": [
      "^ls\\b",
      "^pwd\\b",
      "^cat\\b",
      "^head\\b",
      "^tail\\b",
      "^echo\\b",
      "^date\\b",
      "^whoami\\b",
      "^df\\b",
      "^free\\b",
      "^uname\\b",
      "^uptime\\b",
      "^git status\\b",
      "^git log\\b",
      "^python3?\\s+-c\\b"
    ],
    "denylist": [
      "rm\\s+-rf",
      "\\bdd\\b",
      "mkfs",
      "\\bsudo\\b",
      ":\\(\\)\\s*\\{",
      "shutdown",
      "reboot",
      ">\\s*/dev/",
      "chmod\\s+-R",
      "chown\\s+-R",
      "curl[^|]*\\|\\s*(sh|bash)",
      "wget[^|]*\\|\\s*(sh|bash)"
    ],
    "max_output_chars": 2000
  }
}