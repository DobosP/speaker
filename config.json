{
  "vad_threshold": 0.01,
  "silence_duration": 1.5,
  "sample_rate": 16000,
  "input_device": null,
  "output_device": null,
  "llm_model": "gemma3:latest",
  "stt_model": "base",
  "runtime_profile": "balanced",
  "transport_mode": "local_lan",
  "local_only": true,
  "tts_voice": "en-US",
  "tts_backend": null,
  "barge_in_pre_roll_sec": 0.3,
  "barge_in_min_speech_sec": 0.15,
  "barge_in_rms_ratio": 2.0,
  "barge_in_cooldown_sec": 0.5,
  "barge_in_use_webrtcvad": true,
  "wakeword_enabled": false,
  "wakeword": null,
  "wakeword_threshold": 0.5,
  "wakeword_timeout_sec": 5.0,
  "wakeword_model_path": null,
  "wakeword_service_mode": "local",
  "wakeword_policy": "strict_required",
  "wakeword_miss_limit": 80,
  "wakeword_recovery_window_sec": 3.0,
  "speaker_verify_enabled": false,
  "speaker_enrollment_wav": null,
  "speaker_verify_threshold": 0.55,
  "diagnostics_log_path": null,
  "diagnostics_log_frames": false,
  "mode": "controller",
  "partial_interval_sec": 0.35,
  "partial_stt_model": "tiny",
  "partial_stt_backend": "whispercpp",
  "live_partial_log": true,
  "live_partial_mode": "newline",
  "adaptive_vad": true,
  "vad_noise_multiplier": 2.5,
  "vad_noise_floor_min": 0.003,
  "calibrate_on_start": true,
  "calibrate_duration_sec": 2.5,
  "aec_enabled": true,
  "aec_strength": 0.3,
  "aec_filter_ms": 150.0,
  "aec_max_ref_sec": 20.0,
  "simple_voiced_fallback": true,
  "barge_in_debug": false,
  "barge_in_min_delay_sec": 0.5,
  "echo_corr_threshold": 0.45,
  "barge_in_min_delay_after_ref_sec": 0.35,
  "barge_in_min_rms_ratio": 3.0,
  "stop_mode": "exact",
  "stop_phrases": [
    "stop",
    "quit",
    "exit"
  ],
  "streaming_llm": true,
  "chunked_tts": true,
  "controller_min_interrupt_delay_sec": 0.2,
  "controller_min_barge_in_sec": 0.12,
  "controller_min_partial_chars": 3,
  "controller_max_partial_age_sec": 1.5,
  "controller_echo_similarity_threshold": 0.7,
  "controller_allow_rms_fallback": false,
  "controller_require_partial_for_barge_in": false,
  "controller_strong_voiced_multiplier": 2.0,
  "controller_interruption_strategy": "balanced",
  "controller_ignore_phrases": [
    "",
    ".",
    "uh",
    "um"
  ],
  "test_timeout": null,
  "memory_smart_save": true,
  "memory_flush_interval_sec": 240,
  "memory_enable_embeddings": false,
  "memory_persist_assistant": false,
  "memory_llm_clean": true,
  "memory": {
    "save_interval_sec": 240,
    "min_confidence": 0.55,
    "llm_cleanup": true,
    "llm_gate": true,
    "cleanup_model": "gemma3:1b",
    "max_buffer_items": 32,
    "min_chars": 3,
    "dedupe_similarity": 0.92,
    "persist_user_only": true,
    "save_control_phrases": false
  },
  "agent_enabled": false,
  "agent_trigger_phrases": ["computer", "agent", "hey computer"],
  "agent_confirm_timeout_sec": 8.0,
  "agent_confirm_yes_phrases": [],
  "agent_confirm_no_phrases": [],
  "agent_brain": {
    "model": "ollama/gemma3:latest",
    "api_base": "http://localhost:11434",
    "api_key_env": null,
    "offline": true,
    "vision_model": null,
    "os_mode": false,
    "web_tool": "oi",
    "screenshot_dir": null,
    "auto_run": false,
    "confirm_mode": "auto_safe",
    "allowlist": [
      "^ls\\b", "^pwd\\b", "^cat\\b", "^head\\b", "^tail\\b", "^echo\\b",
      "^date\\b", "^whoami\\b", "^df\\b", "^free\\b", "^uname\\b", "^uptime\\b",
      "^git status\\b", "^git log\\b", "^python3?\\s+-c\\b"
    ],
    "denylist": [
      "rm\\s+-rf", "\\bdd\\b", "mkfs", "\\bsudo\\b", ":\\(\\)\\s*\\{",
      "shutdown", "reboot", ">\\s*/dev/", "chmod\\s+-R", "chown\\s+-R",
      "curl[^|]*\\|\\s*(sh|bash)", "wget[^|]*\\|\\s*(sh|bash)"
    ],
    "max_output_chars": 2000
  }
}
