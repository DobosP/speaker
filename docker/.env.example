# Copy to .env at the repo root: `cp docker/.env.example .env`

# LiveKit credentials. These defaults match `livekit-server --dev`; change BOTH
# (and stop using --dev) before exposing the server beyond your LAN.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# URL the worker AND browsers use to reach the LiveKit server.
#   Same machine only:        ws://127.0.0.1:7880
#   Other laptops on the LAN:  ws://<THIS_HOST_LAN_IP>:7880
LIVEKIT_URL=ws://127.0.0.1:7880

# Only needed if you override sherpa models with a gated HuggingFace repo.
HUGGINGFACE_TOKEN=
