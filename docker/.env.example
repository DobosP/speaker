# Copy to .env in the docker/ dir: `cp docker/.env.example docker/.env`
#
# Two flows share this file:
#
# (A) The cloud-streaming console (docker/docker-compose.yml). Ollama runs in
#     a sibling container with GPU access; the speaker container talks to it
#     via http://ollama:11434, which the compose file sets for you. You only
#     need the four cloud LLM keys below.
#
# (B) The remote/LiveKit host (docker/docker-compose.remote.yml, if you use
#     it). Ollama runs on the HOST; set OLLAMA_HOST below + LIVEKIT_*.

# === Flow A: cloud-streaming console ======================================

# Cloud LLM provider keys (PR-1). Missing keys silently disable that provider;
# the sensitivity-routed chain falls through to whichever providers are set,
# finally to local Ollama via HedgeLLM. Set at least one to actually exercise
# the cloud middle layer.
#
# See https://cloud.cerebras.ai/platform, https://console.groq.com/keys,
# https://platform.deepseek.com/api_keys, https://platform.moonshot.ai/console/api-keys.
CEREBRAS_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=

# === Flow B: remote/LiveKit host (optional) ===============================

# The LLM runs in your HOST-LOCAL Ollama (not a container). Make sure it is
# running (`ollama serve`) and the models are pulled on the host:
#   ollama pull gemma3:12b && ollama pull gemma3:4b
#
# With host networking the app reaches Ollama at localhost:11434 automatically,
# so OLLAMA_HOST can stay empty. Set it only if Ollama listens elsewhere, e.g.
# OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_HOST=

# How long Ollama keeps the model resident after a turn. Longer = no cold reload
# on the next question (snappier first token), at the cost of holding VRAM.
# "30m" is the config default; use "-1" to keep it resident forever on a
# dedicated box. Empty here falls back to the config.json value.
OLLAMA_KEEP_ALIVE=

# LiveKit credentials. REQUIRED: the default (non-dev) stack fails fast if these
# are unset -- generate a strong random key/secret pair and set BOTH.
# Only the explicit dev overlay (docker-compose.dev.yml) runs the SFU with --dev,
# which accepts the well-known devkey/secret; set them to those two literals if
# (and only if) you use that local-only overlay.
LIVEKIT_API_KEY=REPLACE_ME
LIVEKIT_API_SECRET=REPLACE_ME

# URL the worker AND browsers use to reach the LiveKit server.
#   Same machine only:        ws://127.0.0.1:7880
#   Other laptops on the LAN:  ws://<THIS_HOST_LAN_IP>:7880
LIVEKIT_URL=ws://127.0.0.1:7880

# Only needed if you override sherpa models with a gated HuggingFace repo.
HUGGINGFACE_TOKEN=
