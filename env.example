# Voice Assistant Configuration
# Copy this file to .env and fill in your values

# Database Configuration
# Format: postgresql://[user[:password]@][host][:port][/database]
# For local peer authentication (no password): postgresql:///database_name
# For password authentication: postgresql://user:password@localhost/database_name
DATABASE_URL=postgresql:///voice_assistant

# Smart memory (optional overrides; see MEMORY.md and config.json "memory")
# MEMORY_CLEANUP_MODEL=gemma3:1b
# OLLAMA_MEMORY_MODEL=gemma3:1b

# Database Setup Options (used by setup.sh)
DB_NAME=voice_assistant
DB_USER=dobo
DB_HOST=localhost
DB_PORT=5432
# Leave DB_PASSWORD empty for peer authentication
DB_PASSWORD=

# PostgreSQL Superuser (for creating extensions)
# Leave empty to use default 'postgres' user
PG_SUPERUSER=postgres

# Smart memory (optional overrides for config.json "memory" block)
# MEMORY_CLEANUP_MODEL=gemma3:1b
